<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Allow cleartext HTTP for local/Tailscale homelab endpoints.
        Remove this and switch to HTTPS when the backend gets a cert.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.1.2</domain>
        <domain includeSubdomains="false">100.95.124.110</domain>
    </domain-config>
</network-security-config>
