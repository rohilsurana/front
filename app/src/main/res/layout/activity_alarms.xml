<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F7">

    <!-- Permission banner — shown when SCHEDULE_EXACT_ALARM not granted -->
    <LinearLayout
        android:id="@+id/layoutPermissionBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#FFF3CD"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚠️ Exact alarm permission needed for alarms to fire on time"
            android:textSize="12sp"
            android:textColor="#856404" />

        <Button
            android:id="@+id/btnGrantPermission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grant"
            android:textSize="12sp"
            style="@style/Widget.AppCompat.Button.Borderless" />

    </LinearLayout>

    <!-- Sync bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvLastSync"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Never synced"
                android:textSize="13sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tvSyncError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:textSize="12sp"
                android:textColor="#C62828"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressSync"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone"
            style="?android:attr/progressBarStyleSmall" />

        <Button
            android:id="@+id/btnSync"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sync"
            style="@style/Widget.AppCompat.Button.Borderless" />

    </LinearLayout>

    <!-- Alarm list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAlarms"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No alarms synced yet.\nTap Sync to fetch from the backend."
        android:textColor="#888888"
        android:textSize="15sp"
        android:visibility="gone" />

</LinearLayout>
