<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Location permission banner -->
        <LinearLayout
            android:id="@+id/layoutPermissionBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@color/colorWarningBg"
            android:visibility="gone">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_warning"
                android:tint="@color/colorWarningText"
                android:contentDescription="Warning" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Location permission needed for GPS tracking"
                android:textSize="12sp"
                android:textColor="@color/colorWarningText" />

            <Button
                android:id="@+id/btnGrantPermission"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grant"
                android:textSize="12sp"
                android:textColor="@color/colorAccent"
                style="@style/Widget.AppCompat.Button.Borderless" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- GPS card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false"
                app:cardBackgroundColor="@color/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPS LOCATION"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="12dp"
                            android:src="@drawable/ic_location_on"
                            android:tint="@color/colorAccent"
                            android:contentDescription="GPS" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Record location"
                                android:textSize="15sp"
                                android:textColor="@color/colorTextPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Logs GPS coordinates in the background"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextSecondary"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchGpsEnabled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <include
                        android:id="@+id/intervalGps"
                        layout="@layout/view_interval_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Battery card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false"
                app:cardBackgroundColor="@color/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BATTERY"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="12dp"
                            android:src="@drawable/ic_battery_std"
                            android:tint="@color/colorAccent"
                            android:contentDescription="Battery" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Record battery percentage"
                                android:textSize="15sp"
                                android:textColor="@color/colorTextPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Logs battery level and charging state"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextSecondary"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchBatteryEnabled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <include
                        android:id="@+id/intervalBattery"
                        layout="@layout/view_interval_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Steps card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false"
                app:cardBackgroundColor="@color/colorSurface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="STEPS" android:textSize="11sp" android:textStyle="bold"
                        android:letterSpacing="0.08" android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="16dp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:layout_marginEnd="12dp" android:src="@drawable/ic_directions_walk"
                            android:tint="@color/colorAccent" android:contentDescription="Steps" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Count steps" android:textSize="15sp" android:textColor="@color/colorTextPrimary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Tracks step count and delta per interval" android:textSize="12sp"
                                android:textColor="@color/colorTextSecondary" android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchStepsEnabled"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                    <include android:id="@+id/intervalSteps" layout="@layout/view_interval_row"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="20dp" android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Activity card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false"
                app:cardBackgroundColor="@color/colorSurface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PHYSICAL ACTIVITY" android:textSize="11sp" android:textStyle="bold"
                        android:letterSpacing="0.08" android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="16dp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:layout_marginEnd="12dp" android:src="@drawable/ic_directions_run"
                            android:tint="@color/colorAccent" android:contentDescription="Activity" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Detect activity" android:textSize="15sp" android:textColor="@color/colorTextPrimary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Stationary / walking / running via step rate"
                                android:textSize="12sp" android:textColor="@color/colorTextSecondary" android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchActivityEnabled"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                    <include android:id="@+id/intervalActivity" layout="@layout/view_interval_row"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="20dp" android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- WiFi card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false"
                app:cardBackgroundColor="@color/colorSurface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="WIFI" android:textSize="11sp" android:textStyle="bold"
                        android:letterSpacing="0.08" android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="16dp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:layout_marginEnd="12dp" android:src="@drawable/ic_wifi"
                            android:tint="@color/colorAccent" android:contentDescription="WiFi" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Record WiFi network" android:textSize="15sp" android:textColor="@color/colorTextPrimary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Logs connected SSID and signal strength"
                                android:textSize="12sp" android:textColor="@color/colorTextSecondary" android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchWifiEnabled"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                    <include android:id="@+id/intervalWifi" layout="@layout/view_interval_row"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="20dp" android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Screen card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false"
                app:cardBackgroundColor="@color/colorSurface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SCREEN" android:textSize="11sp" android:textStyle="bold"
                        android:letterSpacing="0.08" android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="16dp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:layout_marginEnd="12dp" android:src="@drawable/ic_phone_android"
                            android:tint="@color/colorAccent" android:contentDescription="Screen" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Record screen state" android:textSize="15sp" android:textColor="@color/colorTextPrimary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Logs whether screen is on or off"
                                android:textSize="12sp" android:textColor="@color/colorTextSecondary" android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchScreenEnabled"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                    <include android:id="@+id/intervalScreen" layout="@layout/view_interval_row"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="20dp" android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Network connection card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false"
                app:cardBackgroundColor="@color/colorSurface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="NETWORK" android:textSize="11sp" android:textStyle="bold"
                        android:letterSpacing="0.08" android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="16dp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:layout_marginEnd="12dp" android:src="@drawable/ic_signal_cellular_alt"
                            android:tint="@color/colorAccent" android:contentDescription="Network" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Record connection type" android:textSize="15sp" android:textColor="@color/colorTextPrimary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Logs WiFi / 4G / 5G / none"
                                android:textSize="12sp" android:textColor="@color/colorTextSecondary" android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchConnectionEnabled"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                    <include android:id="@+id/intervalConnection" layout="@layout/view_interval_row"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="20dp" android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Status card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false"
                app:cardBackgroundColor="@color/colorSurface"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPLOAD STATUS"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="10dp"
                            android:src="@drawable/ic_my_location"
                            android:tint="@color/colorTextSecondary"
                            android:contentDescription="Buffer" />

                        <TextView
                            android:id="@+id/tvBufferStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 points buffered"
                            android:textSize="14sp"
                            android:textColor="@color/colorTextPrimary" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/colorDivider"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="10dp"
                            android:src="@drawable/ic_sync"
                            android:tint="@color/colorTextSecondary"
                            android:contentDescription="Last upload" />

                        <TextView
                            android:id="@+id/tvLastUpload"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Never uploaded"
                            android:textSize="14sp"
                            android:textColor="@color/colorTextPrimary" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/colorDivider"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <include
                        android:id="@+id/intervalUpload"
                        layout="@layout/view_interval_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
